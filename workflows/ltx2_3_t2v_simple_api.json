{
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "ltx-2.3-22b-dev-fp8.safetensors"
    },
    "_meta": { "title": "Load LTX 2.3 Checkpoint" }
  },
  "2": {
    "class_type": "CLIPLoader",
    "inputs": {
      "clip_name": "t5xxl_fp16.safetensors",
      "type": "ltxv"
    },
    "_meta": { "title": "Load T5 Text Encoder" }
  },
  "3": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "A cat walking gracefully through a sunlit garden, cinematic quality, smooth motion",
      "clip": ["2", 0]
    },
    "_meta": { "title": "Positive Prompt" }
  },
  "4": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "blurry, low quality, distorted, watermark",
      "clip": ["2", 0]
    },
    "_meta": { "title": "Negative Prompt" }
  },
  "5": {
    "class_type": "EmptyLTXVLatentVideo",
    "inputs": {
      "width": 512,
      "height": 320,
      "length": 41,
      "batch_size": 1
    },
    "_meta": { "title": "Empty Video Latent" }
  },
  "6": {
    "class_type": "LTXVConditioning",
    "inputs": {
      "positive": ["3", 0],
      "negative": ["4", 0],
      "frame_rate": 24
    },
    "_meta": { "title": "LTX Conditioning" }
  },
  "7": {
    "class_type": "LTXVScheduler",
    "inputs": {
      "steps": 20,
      "max_shift": 2.05,
      "base_shift": 0.95,
      "stretch": false,
      "terminal": 0.1
    },
    "_meta": { "title": "LTX Scheduler" }
  },
  "11": {
    "class_type": "KSamplerSelect",
    "inputs": {
      "sampler_name": "euler"
    },
    "_meta": { "title": "Sampler Select" }
  },
  "8": {
    "class_type": "SamplerCustom",
    "inputs": {
      "model": ["1", 0],
      "positive": ["6", 0],
      "negative": ["6", 1],
      "latent_image": ["5", 0],
      "add_noise": true,
      "noise_seed": 42,
      "cfg": 1.0,
      "sampler": ["11", 0],
      "sigmas": ["7", 0]
    },
    "_meta": { "title": "Sampler" }
  },
  "9": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["8", 0],
      "vae": ["1", 2]
    },
    "_meta": { "title": "VAE Decode" }
  },
  "10": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["9", 0],
      "filename_prefix": "bench_ltx23"
    },
    "_meta": { "title": "Save Frames" }
  }
